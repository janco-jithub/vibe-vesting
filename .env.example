# Alpaca Paper Trading API
# Get your keys at https://alpaca.markets (it's free, unlike trading courses)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Polygon.io API (optional - we mostly use Alpaca for data now)
POLYGON_API_KEY=your_polygon_key_here

# Environment (paper = fake money, live = real tears)
TRADING_ENV=paper
LOG_LEVEL=INFO

# Database
DATABASE_PATH=data/quant.db
